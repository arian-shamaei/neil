#!/usr/bin/env python3
"""neil-complete-intent <keyword>

Complete an intention by matching a keyword from its description.

Behavior:
  - If matched intention has fulfillment.verify_cmd, run it with timeout.
    - exit 0  -> status=completed, last_verify=pass
    - exit !0 -> status=in_progress, last_verify=fail, attempts++
    - timeout -> status=in_progress, last_verify=timeout, attempts++
  - If no verify_cmd, status=completed (legacy self-attestation behavior).

Matches the most recent pending intention whose description contains <keyword>
(case-insensitive). Falls back to oldest pending if no keyword match.

Exit codes:
  0 = intention completed
  1 = verify failed (intention still pending)
  2 = verify timeout (intention still pending)
  3 = budget exhausted (intention marked timeout)
  10 = no matching pending intention
  11 = intentions.json missing or unreadable
"""

import json
import os
import subprocess
import sys
import time
from pathlib import Path


def main():
    if len(sys.argv) < 2:
        print("usage: neil-complete-intent <keyword>", file=sys.stderr)
        return 11

    keyword = " ".join(sys.argv[1:]).strip()
    neil_home = Path(os.environ.get("NEIL_HOME", os.path.expanduser("~/.neil")))
    path = neil_home / "intentions.json"

    if not path.exists():
        print("intentions.json not found", file=sys.stderr)
        return 11

    # Read all lines (preserve invalid lines as opaque strings)
    entries = []
    for line in path.read_text().splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            entries.append({"_parsed": True, "data": json.loads(line)})
        except json.JSONDecodeError:
            entries.append({"_parsed": False, "raw": line})

    # Find most recent pending whose description contains keyword (case-insensitive)
    target_idx = None
    kw_lower = keyword.lower()
    for i in range(len(entries) - 1, -1, -1):
        if not entries[i]["_parsed"]:
            continue
        e = entries[i]["data"]
        if e.get("status") != "pending":
            continue
        if kw_lower in e.get("description", "").lower():
            target_idx = i
            break

    # Fallback: oldest pending
    if target_idx is None:
        for i, wrap in enumerate(entries):
            if not wrap["_parsed"]:
                continue
            if wrap["data"].get("status") == "pending":
                target_idx = i
                break

    if target_idx is None:
        print(f"no pending intention matching '{keyword}'", file=sys.stderr)
        return 10

    target = entries[target_idx]["data"]
    ful = target.get("fulfillment")

    # No contract -> legacy self-attestation
    if not ful or not ful.get("verify_cmd"):
        target["status"] = "completed"
        ful_state = target.setdefault("fulfillment_state", {})
        ful_state["wall_clock_end"] = time.strftime("%Y-%m-%dT%H-%M-%S")
        entries[target_idx]["data"] = target
        _write_back(path, entries)
        print(f"COMPLETED (no verify): {target.get('description', '')[:80]}", file=sys.stderr)
        return 0

    # Run verify_cmd with timeout
    verify_cmd = ful["verify_cmd"]
    timeout = int(ful.get("verify_timeout_sec", 60))
    state = target.setdefault("fulfillment_state", {})
    state["attempts"] = int(state.get("attempts", 0)) + 1
    if not state.get("wall_clock_start"):
        state["wall_clock_start"] = time.strftime("%Y-%m-%dT%H-%M-%S")

    print(f"VERIFY: running '{verify_cmd}' (timeout {timeout}s)", file=sys.stderr)
    try:
        r = subprocess.run(
            verify_cmd,
            shell=True,
            capture_output=True,
            text=True,
            timeout=timeout,
        )
    except subprocess.TimeoutExpired:
        state["last_verify"] = "timeout"
        state["last_verify_msg"] = f"verify_cmd timed out after {timeout}s"
        target["status"] = "in_progress"
        target["fulfillment_state"] = state
        entries[target_idx]["data"] = target
        _write_back(path, entries)
        print("VERIFY TIMEOUT", file=sys.stderr)
        return 2

    if r.returncode == 0:
        target["status"] = "completed"
        state["last_verify"] = "pass"
        state["last_verify_msg"] = (r.stdout or "").strip()[:500]
        state["wall_clock_end"] = time.strftime("%Y-%m-%dT%H-%M-%S")
        rc = 0
        print(f"COMPLETED (verified): {target.get('description', '')[:80]}", file=sys.stderr)
    else:
        target["status"] = "in_progress"
        state["last_verify"] = "fail"
        msg = (r.stderr or r.stdout or f"exit {r.returncode}").strip()
        state["last_verify_msg"] = msg[:500]
        rc = 1
        print(f"VERIFY FAILED (exit {r.returncode}): {msg[:150]}", file=sys.stderr)

    target["fulfillment_state"] = state
    entries[target_idx]["data"] = target
    _write_back(path, entries)
    return rc


def _write_back(path: Path, entries):
    """Write entries back atomically."""
    tmp = path.with_suffix(".tmp")
    with tmp.open("w") as f:
        for wrap in entries:
            if wrap["_parsed"]:
                f.write(json.dumps(wrap["data"], ensure_ascii=False) + "\n")
            else:
                f.write(wrap["raw"] + "\n")
    tmp.replace(path)


if __name__ == "__main__":
    sys.exit(main())
