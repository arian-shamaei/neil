#!/bin/bash
# neil-cluster-watch — merged live stream of prompt activity across main
# Neil and every ready peer. Each source gets a [tag] prefix; lines
# interleave in real time. Ctrl+C to stop.
#
# Sources:
#   [main]      sealserver autoprompt daemon (CALL/BASH/READ/WRITE/INTEND/DONE/etc.)
#   [<peer>]    each ready peer's autoprompt daemon (same line types)
#   [activity]  ~/.neil/state/cluster_activity.jsonl (peer_send/peer_transfer)
#
# Usage:
#   neil-cluster-watch            # live stream, interesting lines only
#   neil-cluster-watch --all      # do not filter; everything
#   neil-cluster-watch --help

set -u
NEIL_HOME=${NEIL_HOME:-$HOME/.neil}
PEERS_JSON=$NEIL_HOME/state/peers.json
ACTIVITY=$NEIL_HOME/state/cluster_activity.jsonl

FILT='\[autoprompt\] (CALL|BASH|READ|WRITE|INTEND|DONE|MEMORY|executing|done):|intention handoff|peer_send|peer_transfer|\[peer='
SHOW_ALL=0
for arg in "$@"; do
    case "$arg" in
        --help|-h) sed -n '2,16p' "$0" | sed 's|^# \?||'; exit 0 ;;
        --all)     SHOW_ALL=1 ;;
    esac
done
[ "$SHOW_ALL" = 1 ] && FILT='.*'

PIDS=""
cleanup() { kill $PIDS 2>/dev/null || true; wait 2>/dev/null; exit 0; }
trap cleanup INT TERM

tag_prefix() { printf '[%-12s] ' "$1"; }

# [main] tailer
(
    sudo journalctl -u autoprompt.service -f -n 0 --output=cat 2>/dev/null         | grep --line-buffered -E "$FILT"         | awk -v t="main" '{ printf "[%-12s] %s\n", t, $0; fflush(); }'
) & PIDS="$PIDS $!"

# [<peer>] tailers
if [ -f "$PEERS_JSON" ]; then
    while IFS= read -r peer; do
        [ -z "$peer" ] && continue
        (
            /snap/bin/lxc exec "$peer" -- journalctl -u neil-autoprompt.service -f -n 0 --output=cat 2>/dev/null                 | grep --line-buffered -E "$FILT"                 | awk -v t="$peer" '{ printf "[%-12s] %s\n", t, $0; fflush(); }'
        ) & PIDS="$PIDS $!"
    done < <(python3 -c "
import json
try: d = json.load(open('$PEERS_JSON'))
except Exception: exit(0)
for k, v in d.items():
    if v.get('status') == 'ready': print(k)
")
fi

# [activity] tailer with JSON → summary extraction
(
    tail -F "$ACTIVITY" 2>/dev/null         | python3 -u -c "
import sys, json
for line in sys.stdin:
    try:
        d = json.loads(line)
    except Exception:
        continue
    ts    = d.get('ts', '')
    evt   = d.get('event', '')
    peer  = d.get('peer', '')
    extras = []
    for k in ('bytes', 'ssh_rc', 'rc', 'waited_sec', 'subject'):
        if k in d: extras.append(f'{k}={d[k]}')
    rh = d.get('reply_head') or d.get('ready_head') or ''
    if rh: extras.append('head=' + repr(rh[:80]))
    sys.stdout.write(f\"[activity    ] {ts} {evt} peer={peer} {' '.join(extras)}\n\")
    sys.stdout.flush()
"
) & PIDS="$PIDS $!"

wait
