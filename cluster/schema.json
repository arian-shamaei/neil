{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Neil Cluster Instance",
  "type": "object",
  "required": ["id", "name", "provider", "status", "created"],
  "properties": {
    "id": {"type": "string"},
    "name": {"type": "string"},
    "provider": {"type": "string", "enum": ["hetzner", "digitalocean", "lambda", "dry-run"]},
    "size": {"type": "string"},
    "region": {"type": "string"},
    "ip": {"type": ["string", "null"]},
    "status": {"type": "string", "enum": ["provisioning", "running", "stopped", "destroyed", "dry-provisioned"]},
    "created": {"type": "string", "format": "date-time"},
    "last_heartbeat": {"type": ["string", "null"], "format": "date-time"},
    "transport": {"type": "string", "enum": ["ssh", "http", "file"]},
    "queue_path": {"type": "string"}
  }
}